<!DOCTYPE html>
<html>
  <head><title>Users</title></head>
  <body>
    <h1>Users</h1>
    <a href="/users/new">New User</a> | <a href="/clubs">View Clubs</a>
    <ul>
      <% users.forEach(u => { %>
        <li>
          <strong><%= u.name %></strong> - <%= u.email %> - <%= u.major %>
          <a href="/users/<%= u._id %>/edit">Edit</a>
          <form action="/users/<%= u._id %>?_method=DELETE" method="POST" style="display:inline;">
            <button type="submit">Delete</button>
          </form>
        </li>
      <% }) %>
    </ul>
  </body>
</html>
